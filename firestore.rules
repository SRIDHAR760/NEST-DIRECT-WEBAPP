rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /properties/{propertyId} {
      allow read, write: if true;
    }
    match /inquiries/{inquiryId} {
      allow read, write: if true;
    }
    match /chat_messages/{messageId} {
      allow read, write: if true;
    }
  }
}
